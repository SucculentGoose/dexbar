<Window
    x:Class="DexBarWindows.Windows.PopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:DexBarWindows.Controls"
    WindowStyle="None"
    Background="#1C1C1E"
    Width="380"
    Height="482"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    TextElement.Foreground="#F0F0F2"
    FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Flat button template used throughout this popup -->
        <ControlTemplate x:Key="FlatButton" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
            </Border>
        </ControlTemplate>
    </Window.Resources>

    <Grid>

        <DockPanel LastChildFill="True">

            <!-- 1. Stale banner (28px) -->
            <Border x:Name="StalePanel"
                    DockPanel.Dock="Top"
                    Height="28"
                    Background="#FF8C00"
                    Visibility="Collapsed">
                <TextBlock Text="⚠  No new readings for 20+ min"
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- 2. Header (100px) -->
            <Border DockPanel.Dock="Top"
                    Height="100"
                    Padding="16,12,16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: glucose value + trend -->
                    <StackPanel Grid.Column="0"
                                Orientation="Vertical"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="GlucoseValueLabel"
                                   Text="--"
                                   FontFamily="Segoe UI"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#F0F0F2" />
                        <TextBlock x:Name="TrendLabel"
                                   Text="Loading..."
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="#A0A0A8"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Right: status + updated + countdown -->
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="StatusLabel"
                                   Text="Disconnected"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="#A0A0A8"
                                   TextAlignment="Right" />
                        <TextBlock x:Name="UpdatedLabel"
                                   Text=""
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#64646C"
                                   TextAlignment="Right"
                                   Margin="0,2,0,0" />
                        <TextBlock x:Name="CountdownLabel"
                                   Text=""
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="#64646C"
                                   TextAlignment="Right"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Divider -->
            <Rectangle DockPanel.Dock="Top" Height="1" Fill="#3A3A3E" />

            <!-- 4. Chart range buttons (30px) -->
            <Border DockPanel.Dock="Top" Height="30" Padding="16,5,16,0">
                <UniformGrid x:Name="ChartRangeFlow"
                             Rows="1"
                             VerticalAlignment="Center" />
            </Border>

            <!-- 5. GlucoseChartControl host (140px) -->
            <Grid x:Name="ChartHost"
                  DockPanel.Dock="Top"
                  Height="140" />

            <!-- 6. Divider -->
            <Rectangle DockPanel.Dock="Top" Height="1" Fill="#3A3A3E" />

            <!-- 7. TiR header (26px) -->
            <Border DockPanel.Dock="Top" Height="26" Padding="16,8,0,0">
                <TextBlock x:Name="TirHeaderLabel"
                           Text="Time in Range"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="#A0A0A8"
                           VerticalAlignment="Top" />
            </Border>

            <!-- 8. Stats range buttons (28px) -->
            <Border DockPanel.Dock="Top" Height="28" Padding="16,4,16,0">
                <UniformGrid x:Name="StatsRangeFlow"
                             Rows="1"
                             VerticalAlignment="Center" />
            </Border>

            <!-- 9. TiR bar (16px with 4px top padding, 16px horizontal padding) -->
            <Border DockPanel.Dock="Top" Height="16" Padding="16,4,16,0">
                <controls:TirBarControl x:Name="TirBar" />
            </Border>

            <!-- 10. TiR percentages (26px) -->
            <Grid DockPanel.Dock="Top" Height="26" Margin="16,4,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="LowPctLabel"
                           Grid.Column="0"
                           Text="↓ 0%"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#A0A0A8"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="InRangePctLabel"
                           Grid.Column="1"
                           Text="✓ 0%"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#A0A0A8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="HighPctLabel"
                           Grid.Column="2"
                           Text="↑ 0%"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#A0A0A8"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- 11. GMI label (24px) -->
            <Border DockPanel.Dock="Top" Height="24" Padding="16,4,16,0">
                <TextBlock x:Name="GmiLabel"
                           Text=""
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#64646C"
                           VerticalAlignment="Top" />
            </Border>

            <!-- 12. Divider -->
            <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="#3A3A3E" />

            <!-- 13. Action buttons -->
            <Grid DockPanel.Dock="Bottom" Height="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="RefreshButton" Grid.Column="0"
                           Text="↺  Refresh Now"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#F0F0F2"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Cursor="Hand" />
                <Rectangle Grid.Column="1" Width="1" Fill="#3A3A3E" Margin="0,8,0,8" />
                <TextBlock x:Name="SettingsButton" Grid.Column="2"
                           Text="⚙  Settings…"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#F0F0F2"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Cursor="Hand" />
                <Rectangle Grid.Column="3" Width="1" Fill="#3A3A3E" Margin="0,8,0,8" />
                <TextBlock x:Name="QuitButton" Grid.Column="4"
                           Text="✕  Quit"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#F0F0F2"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Cursor="Hand" />
            </Grid>

        </DockPanel>

    </Grid>

</Window>
