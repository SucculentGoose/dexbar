<Page x:Class="DexBarWindows.Pages.DisplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent"
      FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" MaxWidth="520">

            <!-- Page title -->
            <TextBlock Text="Display"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#F0F0F2"
                       Margin="0,0,0,20" />

            <!-- Blood Sugar Unit -->
            <TextBlock Text="BLOOD SUGAR UNIT"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#64646C"
                       Margin="0,0,0,8" />
            <ui:CardControl Margin="0,0,0,16">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Unit" FontSize="13" Foreground="#F0F0F2" />
                        <TextBlock Text="Choose how glucose values are displayed"
                                   FontSize="11" Foreground="#A0A0A8" />
                    </StackPanel>
                </ui:CardControl.Header>
                <WrapPanel VerticalAlignment="Center">
                    <RadioButton x:Name="RdMgdL"
                                 Content="mg/dL"
                                 GroupName="UnitGroup"
                                 Margin="0,0,16,0"
                                 Foreground="#F0F0F2"
                                 Checked="RdMgdL_Checked" />
                    <RadioButton x:Name="RdMmolL"
                                 Content="mmol/L"
                                 GroupName="UnitGroup"
                                 Foreground="#F0F0F2"
                                 Checked="RdMmolL_Checked" />
                </WrapPanel>
            </ui:CardControl>

            <!-- Refresh Interval -->
            <TextBlock Text="REFRESH INTERVAL"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#64646C"
                       Margin="0,0,0,8" />
            <ui:CardControl Margin="0,0,0,16">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Polling interval" FontSize="13" Foreground="#F0F0F2" />
                        <TextBlock Text="How often to fetch new readings"
                                   FontSize="11" Foreground="#A0A0A8" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox x:Name="CmbRefresh"
                          Width="140"
                          Background="#2C2C2E"
                          Foreground="#F0F0F2"
                          BorderBrush="#48484E"
                          SelectionChanged="CmbRefresh_SelectionChanged" />
            </ui:CardControl>

            <!-- Options -->
            <TextBlock Text="OPTIONS"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#64646C"
                       Margin="0,0,0,8" />
            <ui:CardControl Margin="0,0,0,2">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Show delta" FontSize="13" Foreground="#F0F0F2" />
                        <TextBlock Text="Display the change since the last reading (e.g. +3 or −0.2)"
                                   FontSize="11" Foreground="#A0A0A8" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="TglShowDelta"
                                 Checked="TglShowDelta_Toggled"
                                 Unchecked="TglShowDelta_Toggled" />
            </ui:CardControl>
            <ui:CardControl Margin="0,2,0,2">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Color-coded tray icon" FontSize="13" Foreground="#F0F0F2" />
                        <TextBlock Text="Tray icon changes color based on glucose range"
                                   FontSize="11" Foreground="#A0A0A8" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="TglColoredIcon"
                                 Checked="TglColoredIcon_Toggled"
                                 Unchecked="TglColoredIcon_Toggled" />
            </ui:CardControl>
            <ui:CardControl Margin="0,2,0,16">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Launch at login" FontSize="13" Foreground="#F0F0F2" />
                        <TextBlock Text="Start DexBar automatically when you log in to Windows"
                                   FontSize="11" Foreground="#A0A0A8" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="TglLaunchAtLogin"
                                 Checked="TglLaunchAtLogin_Toggled"
                                 Unchecked="TglLaunchAtLogin_Toggled" />
            </ui:CardControl>

            <!-- Range Colors -->
            <TextBlock Text="RANGE COLORS"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#64646C"
                       Margin="0,0,0,8" />

            <!-- Urgent Low -->
            <ui:CardControl Margin="0,0,0,2">
                <ui:CardControl.Header>
                    <TextBlock Text="Urgent Low" FontSize="13" Foreground="#F0F0F2" />
                </ui:CardControl.Header>
                <Border x:Name="SwatchUrgentLow"
                        Width="32" Height="22"
                        CornerRadius="4"
                        Cursor="Hand"
                        MouseLeftButtonUp="SwatchUrgentLow_Click" />
            </ui:CardControl>

            <!-- Low -->
            <ui:CardControl Margin="0,2,0,2">
                <ui:CardControl.Header>
                    <TextBlock Text="Low" FontSize="13" Foreground="#F0F0F2" />
                </ui:CardControl.Header>
                <Border x:Name="SwatchLow"
                        Width="32" Height="22"
                        CornerRadius="4"
                        Cursor="Hand"
                        MouseLeftButtonUp="SwatchLow_Click" />
            </ui:CardControl>

            <!-- In Range -->
            <ui:CardControl Margin="0,2,0,2">
                <ui:CardControl.Header>
                    <TextBlock Text="In Range" FontSize="13" Foreground="#F0F0F2" />
                </ui:CardControl.Header>
                <Border x:Name="SwatchInRange"
                        Width="32" Height="22"
                        CornerRadius="4"
                        Cursor="Hand"
                        MouseLeftButtonUp="SwatchInRange_Click" />
            </ui:CardControl>

            <!-- High -->
            <ui:CardControl Margin="0,2,0,2">
                <ui:CardControl.Header>
                    <TextBlock Text="High" FontSize="13" Foreground="#F0F0F2" />
                </ui:CardControl.Header>
                <Border x:Name="SwatchHigh"
                        Width="32" Height="22"
                        CornerRadius="4"
                        Cursor="Hand"
                        MouseLeftButtonUp="SwatchHigh_Click" />
            </ui:CardControl>

            <!-- Urgent High -->
            <ui:CardControl Margin="0,2,0,0">
                <ui:CardControl.Header>
                    <TextBlock Text="Urgent High" FontSize="13" Foreground="#F0F0F2" />
                </ui:CardControl.Header>
                <Border x:Name="SwatchUrgentHigh"
                        Width="32" Height="22"
                        CornerRadius="4"
                        Cursor="Hand"
                        MouseLeftButtonUp="SwatchUrgentHigh_Click" />
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>

</Page>
