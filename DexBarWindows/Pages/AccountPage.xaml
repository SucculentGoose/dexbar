<Page x:Class="DexBarWindows.Pages.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent"
      FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" MaxWidth="520">

            <!-- Page title -->
            <TextBlock Text="Account"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#F0F0F2"
                       Margin="0,0,0,20" />

            <!-- Username -->
            <TextBlock Text="Dexcom Username / Email"
                       FontSize="12"
                       Foreground="#A0A0A8"
                       Margin="0,0,0,4" />
            <TextBox x:Name="TxtUsername"
                     FontSize="13"
                     Margin="0,0,0,14"
                     Padding="8,6"
                     Background="#2C2C2E"
                     Foreground="#F0F0F2"
                     BorderBrush="#48484E"
                     BorderThickness="1"
                     CaretBrush="#F0F0F2" />

            <!-- Password -->
            <TextBlock Text="Password"
                       FontSize="12"
                       Foreground="#A0A0A8"
                       Margin="0,0,0,4" />
            <PasswordBox x:Name="TxtPassword"
                         FontSize="13"
                         Margin="0,0,0,14"
                         Padding="8,6"
                         Background="#2C2C2E"
                         Foreground="#F0F0F2"
                         BorderBrush="#48484E"
                         BorderThickness="1"
                         CaretBrush="#F0F0F2" />

            <!-- Region -->
            <TextBlock Text="Region"
                       FontSize="12"
                       Foreground="#A0A0A8"
                       Margin="0,0,0,4" />
            <ComboBox x:Name="CmbRegion"
                      FontSize="13"
                      Width="200"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,20"
                      Padding="8,6"
                      Background="#2C2C2E"
                      Foreground="#F0F0F2"
                      BorderBrush="#48484E"
                      BorderThickness="1" />

            <!-- Connect button -->
            <Button x:Name="BtnConnect"
                    Content="Connect"
                    Width="120"
                    Height="36"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16"
                    Background="#0A84FF"
                    Foreground="White"
                    FontSize="13"
                    FontWeight="Medium"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnConnect_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#1A94FF" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="BtnBorder" Property="Background" Value="#3A3A3E" />
                                            <Setter Property="Foreground" Value="#64646C" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Status InfoBar -->
            <ui:InfoBar x:Name="StatusBar"
                        IsOpen="False"
                        IsClosable="False"
                        Margin="0,0,0,0" />

        </StackPanel>
    </ScrollViewer>

</Page>
